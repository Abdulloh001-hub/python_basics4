# PERSON CLASS (Parent class)
class Person:
    def __init__(self, name, surname, birthdate, ID, bplace):
        self.name = name
        self.surname = surname
        self.birthdate = birthdate
        self.__ID = ID
        self.bplace = bplace

    # def __str__(self):
    #     return f"{self.name} {self.surname}"
    def get_name(self):
        return self.name

    def get_surname(self):
        return self.surname

    def get_fullname(self):
        return f"{self.name} {self.surname}"

    def get_age(self, current_date):
        return current_date - self.birthdate

    def get_ID(self):
        return self.__ID

    def get_info(self):
        return f"""
        Name: {self.name}
        Surname: {self.surname}
        Birthdate: {self.birthdate}
        Birth place: {self.bplace}
        ID: {self.__ID}"""

# STUDENT CLASS
class Talaba(Person):
    def __init__(self, name, surname, birthdate, ID, bplace, group):
        super().__init__(name, surname, birthdate, ID, bplace)
        self.group = group
    
    def get_group(self):
        return self.group

    def get_info(self):
        return super().get_info()+f"\nGroup: {self.group}"

# TEACHER CLASS
class Teacher(Person):
    def __init__(self, name, surname, birthdate, ID, bplace, subject):
        super().__init__(name, surname, birthdate, ID, bplace)
        self.subject = subject

    def get_info(self):
        return super().get_info() + f"Subject: {self.subject}\n"


# COURSE CLASS (ENG MUHIM QISM)
class Course:
    def __init__(self, course_name, teacher):
        self.course_name = course_name
        self.teacher = teacher
        self.students = []
    
    def get_students(self):
        return self.students

    def add_student(self, student):
        self.students.append(student)

    def get_course_info(self):
        print(f"\n Course: {self.course_name}")
        print(f" Teacher: {self.teacher.get_fullname()}")
        print(f" Talabalar soni {len(self.students)}")
        print("\n Students:")

        for s in self.students:
            print(f"- {s.get_fullname()}")

    def show_full_details(self):
        print(f"\n========== COURSE DETAILS ==========")
        print(f"Course: {self.course_name}")

        print("\n--- Teacher Info ---")
        print(self.teacher.get_info())

        print("\n--- Students Info ---")
        for talaba in self.students:
            print(talaba.get_info())

